+def parse_class_assigned(class_assigned: str) -> tuple[str, str]:
+    """
+    Splits the 'Assigned Class' string used by the Staff form
+    (e.g. 'Grade 10 - Section A') into (grade_level, stream_section).
+    Falls back to a 'Main' stream if no section is present, since
+    class_teacher_assignments.stream_section is NOT NULL.
+    """
+    if " - Section " in class_assigned:
+        grade_level, stream_section = class_assigned.split(" - Section ", 1)
+        return grade_level.strip(), stream_section.strip()
+    if " - " in class_assigned:
+        grade_level, stream_section = class_assigned.split(" - ", 1)
+        return grade_level.strip(), stream_section.strip()
+    return class_assigned.strip(), "Main"
+
