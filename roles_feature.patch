+++ b/src/react-app/lib/accessControl.ts
@@ -0,0 +1,87 @@
+/**
+ * Single source of truth for role-based access to dashboard routes.
+ *
+ * Previously, role logic only lived in the Sidebar's `navItems` array (which
+ * roles) and Dashboard.tsx's switch block (which dashboard view to render).
+ * That hid links from the nav, but a logged-in user typing a URL directly
+ * (e.g. /dashboard/platform-admin) could still reach the page and call its
+ * backend endpoints, because ProtectedRoute only checked "is authenticated",
+ * never "is this user allowed on this route".
+ *
+ * This map is now used by:
+ *  - Sidebar.tsx, to decide which links to show
+ *  - App.tsx's RoleRoute, to actually block navigation to disallowed routes
+ *
+ * Keep this in sync with server/auth.py's require_roles(...) calls on the
+ * matching API endpoints — the frontend guard is a UX nicety, the backend
+ * guard is the real security boundary.
+ */
+
+export type Role =
+  | 'super_admin'
+  | 'admin'
+  | 'teacher'
+  | 'parent'
+  | 'student'
+  | 'registrar'
+  | 'exam_officer'
+  | 'hod'
+  | 'timetable_manager'
+  | 'transport_manager'
+  | 'class_teacher'
+  | 'boarding_master'
+  | 'cbc_coordinator'
+  | 'hr_manager'
+  | 'admission_officer'
+  | 'nurse';
+
+const ALL_ROLES: Role[] = [
+  'super_admin', 'admin', 'teacher', 'parent', 'student', 'registrar',
+  'exam_officer', 'hod', 'timetable_manager', 'transport_manager',
+  'class_teacher', 'boarding_master', 'cbc_coordinator', 'hr_manager',
+  'admission_officer', 'nurse',
+];
+
+/** Path is matched as a prefix against the current route (see routeAllowsRole). */
+export const routeRoles: { path: string; roles: Role[] }[] = [
+  { path: '/dashboard/schools', roles: ['super_admin'] },
+  { path: '/dashboard/school-admins', roles: ['super_admin'] },
+  { path: '/dashboard/subscriptions', roles: ['super_admin'] },
+  { path: '/dashboard/platform-admin', roles: ['super_admin'] },
+  { path: '/dashboard/students', roles: ['admin', 'teacher', 'registrar', 'exam_officer', 'hod', 'admission_officer', 'class_teacher'] },
+  { path: '/dashboard/staff', roles: ['admin', 'registrar', 'hod', 'hr_manager'] },
+  { path: '/dashboard/academics', roles: ['admin', 'teacher', 'exam_officer', 'hod', 'cbc_coordinator', 'class_teacher'] },
+  { path: '/dashboard/progress', roles: ['parent', 'student'] },
+  { path: '/dashboard/parent', roles: ['parent'] },
+  { path: '/dashboard/student-dashboard', roles: ['student'] },
+  { path: '/dashboard/teacher-dashboard', roles: ['teacher', 'hod', 'class_teacher'] },
+  { path: '/dashboard/timetable-manager', roles: ['timetable_manager', 'admin'] },
+  { path: '/dashboard/timetable', roles: ['admin', 'teacher', 'parent', 'student', 'timetable_manager', 'registrar', 'hod'] },
+  { path: '/dashboard/communications', roles: ['admin', 'teacher', 'parent', 'registrar', 'hod', 'hr_manager', 'admission_officer', 'nurse'] },
+  { path: '/dashboard/fees', roles: ['admin', 'parent', 'student', 'registrar', 'super_admin'] },
+  { path: '/dashboard/leave', roles: ['admin', 'teacher', 'hod', 'hr_manager'] },
+  { path: '/dashboard/reports', roles: ['admin', 'super_admin', 'registrar', 'exam_officer', 'hod', 'hr_manager'] },
+  { path: '/dashboard/cbc', roles: ['admin', 'teacher', 'hod', 'cbc_coordinator'] },
+  { path: '/dashboard/transport', roles: ['admin', 'transport_manager'] },
+  { path: '/dashboard/boarding', roles: ['admin', 'registrar', 'boarding_master'] },
+  { path: '/dashboard/curriculum-assessment', roles: ['admin', 'teacher', 'exam_officer', 'hod', 'cbc_coordinator'] },
+  { path: '/dashboard/settings', roles: ['admin', 'super_admin'] },
+  // Dashboard root and any route not listed above (e.g. detail pages that do
+  // their own record-level checks) are open to any authenticated role.
+];
+
+/**
+ * Longest-prefix match wins, so /dashboard/students/:id inherits /dashboard/students rules.
+ * Accepts the user's full role set (primary + any supplementary roles granted
+ * by an admin) — access is allowed if ANY held role matches.
+ */
+export function routeAllowsRole(pathname: string, roles: string[]): boolean {
+  const candidates = routeRoles
+    .filter(r => pathname === r.path || pathname.startsWith(r.path + '/'))
+    .sort((a, b) => b.path.length - a.path.length);
+
+  if (candidates.length === 0) return true; // no restriction defined -> open to all authenticated roles
+  return candidates[0].roles.some(allowed => roles.includes(allowed));
+}
+
+export { ALL_ROLES };
